{
  "id": "intel-001",
  "category": "intelligence",
  "difficulty": "intelligence",
  "intent": "On Hacker News, find the most discussed post today (highest comment count) and summarize its top 3 comments",
  "start_url": "https://news.ycombinator.com/",
  "requires": {
    "tools": [],
    "engines": [],
    "auth_domains": [],
    "features": [],
    "competitive": false
  },
  "eval": {
    "type": "structured_output",
    "schema": {
      "type": "object",
      "properties": {
        "post_title": {
          "type": "string"
        },
        "comment_count": {
          "type": "number"
        },
        "top_comments": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "post_title",
        "comment_count",
        "top_comments"
      ]
    }
  },
  "eval_fallback": {
    "type": "llm_judge",
    "criteria": "The output must identify a specific Hacker News post by title, report its comment count as a number, and provide at least 3 comment summaries that are coherent English sentences describing the discussion content."
  },
  "timeout_ms": 120000,
  "max_budget_usd": 0.5,
  "tags": [
    "intelligence",
    "hacker-news",
    "live",
    "summarization",
    "comments",
    "ranking"
