  "requires": {
    "tools": ["safari_navigate", "safari_fill", "safari_click", "safari_wait_for", "safari_get_text", "safari_paginate_scrape"],
    "engines": [],
    "auth_domains": [],
    "features": [],
    "competitive": false
  },
  "eval": {
    "type": "structured_output",
    "schema": {
      "type": "object",
      "properties": {
        "all_results": {
          "type": "array",
          "minItems": 9,
          "items": { "type": "string" }
        }
      },
      "required": ["all_results"]
    }
  },
  "timeout_ms": 60000,
  "max_budget_usd": 0.40,
  "tags": ["workflows", "pagination", "fixture", "search", "multi-page", "aggregation"]
